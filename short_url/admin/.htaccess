# 1. フォルダ内のファイル一覧を表示させない
Options -Indexes

# 2. データベースファイル (.sqlite) への直接アクセスを禁止
<Files "*.sqlite">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</Files>

# 3. 重要なシステムファイルへの直接アクセスを禁止
# setup.php: セットアップ完了後はアクセス不要
# init.php: 内部処理用
# config.php: DB情報などの機密保持用（新しく作成を推奨）
<FilesMatch "^(init\.php|config\.php)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>